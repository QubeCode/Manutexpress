# URL publique du site (production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Emails transactionnels (Resend)
RESEND_API_KEY=

# Expéditeur — le domaine doit être vérifié dans Resend (DNS SPF/DKIM)
EMAIL_FROM=MANUTEXPRESS contact@manutexpress.com
EMAIL_TO=contact@manutexpress.com

# En attendant la vérification du domaine, mode test Resend :
# RESEND_SANDBOX=true
# RESEND_SANDBOX_FROM=onboarding@resend.dev

# Stripe Checkout (acompte)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# URL publique du site (production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stockage persistant des demandes de devis (requis en production sur Vercel)
# Option A — Vercel KV (Storage > KV dans le dashboard Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Option B — Upstash Redis directement
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# En local sans Redis, les demandes sont stockées dans data/requests.json
